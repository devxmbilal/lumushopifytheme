        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>Lumu was born from a simple idea: everyone in Pakistan deserves access to high-quality products at fair prices — without the hassle of crowded bazaars or unreliable sellers.</p><p>We curate thousands of products across fashion, electronics, home, beauty, and more — working directly with trusted brands and manufacturers to bring you authentic items backed by our quality guarantee.</p><p>Our mission is to make online shopping effortless, enjoyable, and accessible for every Pakistani household.</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": ["heading", "text"],
      "settings": {
        "height": "auto",
        "desktop_image_width": "medium",
        "layout": "image_first",
        "desktop_content_position": "middle",
        "desktop_content_alignment": "left",
        "content_layout": "no-overlap",
        "color_scheme": "scheme-1",
        "mobile_content_alignment": "left",
        "padding_top": 52,
        "padding_bottom": 52
      }
    },
    "lumu_values": {
      "type": "multicolumn",
      "blocks": {
        "v_1": { "type": "column", "settings": { "title": "🎯 Quality First", "text": "<p>Every product is vetted for quality before it reaches your doorstep. No compromises, ever.</p>" } },
        "v_2": { "type": "column", "settings": { "title": "💰 Best Prices", "text": "<p>We cut out the middlemen and pass the savings directly to you. Great value, guaranteed.</p>" } },
        "v_3": { "type": "column", "settings": { "title": "🤝 Customer Love", "text": "<p>From order to delivery, our support team is here 24/7 to ensure your complete satisfaction.</p>" } }
