        "c_2": { "type": "column", "settings": { "title": "👔 Men", "text": "<p>Shirts, pants, sneakers & grooming essentials</p>", "link_label": "Shop Men →", "link": "shopify://collections/all" } },
        "c_3": { "type": "column", "settings": { "title": "👶 Kids", "text": "<p>Adorable clothing, toys & school supplies</p>", "link_label": "Shop Kids →", "link": "shopify://collections/all" } },
        "c_4": { "type": "column", "settings": { "title": "🏠 Home & Kitchen", "text": "<p>Bedding, cookware, décor & smart gadgets</p>", "link_label": "Shop Home →", "link": "shopify://collections/all" } },
        "c_5": { "type": "column", "settings": { "title": "💄 Beauty & Health", "text": "<p>Skincare, makeup, wellness & fragrances</p>", "link_label": "Shop Beauty →", "link": "shopify://collections/all" } },
        "c_6": { "type": "column", "settings": { "title": "📱 Electronics", "text": "<p>Earbuds, chargers, smartwatches & accessories</p>", "link_label": "Shop Electronics →", "link": "shopify://collections/all" } }
