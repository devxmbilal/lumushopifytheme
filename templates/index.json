      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"lumu-top-bar\"><div class=\"page-width lumu-top-bar__inner\"><span>🚚 FREE Shipping on Orders Over Rs 2,000</span><span>📞 WhatsApp: +92 XXX XXXXXXX</span><span>🔒 100% Secure Checkout</span></div></div><style>.lumu-top-bar{background:linear-gradient(135deg,#8577C7 0%,#6153a7 100%);color:#fff;padding:8px 0;font-size:12px;text-align:center;letter-spacing:0.5px}.lumu-top-bar__inner{display:flex;justify-content:center;gap:30px;flex-wrap:wrap}.lumu-top-bar span{white-space:nowrap}@media(max-width:749px){.lumu-top-bar__inner{gap:15px;font-size:11px}}</style>",
        "color_scheme": "scheme-1",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "hero_banner": {
      "type": "image-banner",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Your One-Stop Shop for <em>Everything</em>",
            "heading_size": "h0"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "From fashion to electronics, home essentials to beauty — shop 100+ categories with free delivery across Pakistan.",
            "text_style": "subtitle"
          }
        },
        "button": {
          "type": "buttons",
          "settings": {
            "button_label_1": "Shop All Products",
            "button_link_1": "shopify://collections/all",
            "button_style_secondary_1": false,
            "button_label_2": "View Collections",
            "button_link_2": "shopify://collections",
            "button_style_secondary_2": true
          }
